{
	"name": "wrd-analyzer",
	"displayName": "wrd-analyzer",
	"description": "Intellisense for WRD files",
	"version": "0.1.0",
	"engines": {
		"vscode": "^1.118.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/Pauisdev/wrd-analyzer"
	},
	"license": "MIT",
	"publisher": "fabrisdev",
	"contributes": {
		"commands": [
			{
				"command": "wrd-analyzer.create-config-files",
				"title": "WRD Analyzer: Create config files"
			}
		],
		"languages": [
			{
				"id": "wrd",
				"aliases": [
					"WRD",
					"wrd"
				],
				"extensions": [
					"_wrdExport.txt"
				],
				"configuration": "./src/syntax/config.json"
			}
		],
		"grammars": [
			{
				"language": "wrd",
				"scopeName": "text.wrd.wrd",
				"path": "./src/syntax/language.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm run compile && pnpm run lint",
		"lint": "eslint src"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.118.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"yaml": "^2.8.4"
	}
}
